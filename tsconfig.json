{
  "compilerOptions": {
    "target": "ES6",
    "module": "CommonJS",
    "moduleResolution": "Node",

    "esModuleInterop": true,
    "strict": true,

    "outDir": "dist",
    "rootDir": ".",

    "ignoreDeprecations": "6.0",
    "resolveJsonModule": true
  },

  "include": ["server.ts", "src"],
  "exclude": ["node_modules", "dist"]
}
